rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Public Read / Authenticated Admin Write Rules
    match /jenjang/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /berita/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /guru/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /siswa/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /program/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /prestasi/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /pengurus/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /agenda/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /galeri/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /settings/{id} { allow read: if true; allow write: if isAuthenticated(); }

    // Public Form Submissions
    match /pendaftaranPPDB/{id} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }
    match /pesanKontak/{id} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // User Accounts
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // Fallback Catch-all for Authenticated Admin Users
    match /{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
